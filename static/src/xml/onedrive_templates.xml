<templates xml:space="preserve">

    <t t-name="onedrive_app" owl="1">
        <div class="o_onedrive_container">

            <!-- HEADER -->
            <div class="o_onedrive_header">

                <button class="btn btn-secondary" t-on-click="goRoot">
                    🏠 Inicio
                </button>

                <button class="btn btn-primary" t-on-click="createFolder">
                    📁 Nueva carpeta
                </button>

                <label class="btn btn-success">
                    ⬆ Subir
                    <input type="file" style="display:none;" t-on-change="uploadFile"/>
                </label>

            </div>

            <!-- BREADCRUMB -->
            <div class="o_onedrive_breadcrumb">
                <span class="breadcrumb-item" t-on-click="goRoot">
                    Inicio
                </span>

                <t t-foreach="state.path" t-as="p" t-index="i" t-key="p.id">
                    <span> / </span>
                    <span class="breadcrumb-item"
                          t-on-click="() => goTo(i)">
                        <t t-esc="p.name"/>
                    </span>
                </t>
            </div>

            <!-- LOADING -->
            <t t-if="state.loading">
                <div>Cargando...</div>
            </t>

            <!-- GRID -->
            <t t-if="!state.loading">
                <div class="o_onedrive_grid">

                    <t t-foreach="state.files" t-as="file" t-key="file.id">
                        <div class="o_onedrive_item">

                            <div class="o_onedrive_icon"
                                 t-on-click="() => openFolder(file)">
                                <t t-if="file.folder">📁</t>
                                <t t-else="">📄</t>
                            </div>

                            <div class="o_onedrive_name">
                                <t t-esc="file.name"/>
                            </div>

                            <div class="o_onedrive_actions">

                                <button class="btn btn-sm btn-outline-primary"
                                        t-on-click="() => downloadItem(file)">
                                    ⬇
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        t-on-click="() => deleteItem(file)">
                                    ❌
                                </button>

                            </div>

                        </div>
                    </t>

                </div>
            </t>

        </div>
    </t>

</templates>