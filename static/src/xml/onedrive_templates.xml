<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="odoo_onedrive_integration.onedrive_app" owl="1">

        <div class="o_onedrive_container">

            <div class="o_onedrive_header">
                <button class="btn btn-secondary" t-on-click="goRoot">🏠 Inicio</button>
                <button class="btn btn-primary" t-on-click="createFolder">📁 Nueva carpeta</button>

                <label class="btn btn-success">
                    ⬆ Subir
                    <input type="file" style="display:none;" t-on-change="uploadFile"/>
                </label>
            </div>

            <t t-if="state.loading">
                <div>Cargando...</div>
            </t>

            <t t-if="!state.loading">
                <div class="o_onedrive_grid">

                    <t t-foreach="state.files" t-as="file" t-key="file.id">
                        <div class="o_onedrive_item">

                            <div class="o_onedrive_icon"
                                 t-on-click="openFolder(file)">
                                <t t-if="file.folder">📁</t>
                                <t t-else="">📄</t>
                            </div>

                            <div class="o_onedrive_name">
                                <t t-esc="file.name"/>
                            </div>

                            <div class="o_onedrive_actions">

                                <!-- SOLO archivos -->
                                <t t-if="!file.folder">
                                    <button class="btn btn-sm btn-outline-primary"
                                            t-on-click="downloadItem(file)">
                                        ⬇
                                    </button>
                                </t>

                                <button class="btn btn-sm btn-outline-danger"
                                        t-on-click="deleteItem(file)">
                                    ❌
                                </button>

                            </div>

                        </div>
                    </t>

                </div>
            </t>

        </div>

    </t>

</templates>